{
  "name": "portal-core",
  "version": "3.0.0",
  "overrides": {
    "ng-mocks": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms",
      "@angular/platform-browser": "$@angular/platform-browser",
      "@angular/platform-browser-dynamic": "$@angular/platform-browser-dynamic",
      "rxjs": "$rxjs",
      "zone.js": "$zone.js"
    }
  },
  "scripts": {
    "ng": "ng",
    "clean": "rimraf dist",
    "postinstall": "npm run build:schematics",
    "prebuild": "node .local-scripts/sync-dependencies.js",
    "build": "ng build @gematik/demis-portal-core-library",
    "build:dev": "npm run clean && npm run build && npm pack dist/gematik/demis-portal-core-library --pack-destination dist",
    "build:schematics": "npm run build --prefix schematics",
    "watch": "ng build @gematik/demis-portal-core-library --watch --configuration production",
    "start": "wait-on dist/gematik/demis-portal-core-library/package.json && ng serve --port 4299",
    "dev": "npm run clean && npm-run-all --parallel watch start",
    "test-local": "ng test @gematik/demis-portal-core-library --karma-config karma.conf.js",
    "test": "ng test @gematik/demis-portal-core-library --karma-config karma.single-run.conf.js",
    "test:coverage": "ng test @gematik/demis-portal-core-library --karma-config karma.coverage.conf.js",
    "deploy-local-dev-package": "node .local-scripts/deploy-local-dev-package.js",
    "restore-to-registry-package": "node .local-scripts/restore-to-registry-package.js"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/core": "21.1.2",
    "@angular-devkit/schematics": "21.1.2",
    "@angular/animations": "21.1.2",
    "@angular/cdk": "21.1.2",
    "@angular/common": "21.1.2",
    "@angular/compiler": "21.1.2",
    "@angular/core": "21.1.2",
    "@angular/forms": "21.1.2",
    "@angular/material": "21.1.2",
    "@angular/material-date-fns-adapter": "21.1.2",
    "@angular/platform-browser": "21.1.2",
    "@angular/platform-browser-dynamic": "21.1.2",
    "@angular/router": "21.1.2",
    "@gematik/demis-portal-theme-library": "1.0.4",
    "@ngx-formly/core": "7.1.0",
    "@ngx-formly/material": "7.1.0",
    "date-fns": "3.6.0",
    "marked": "17.0.1",
    "ngx-highlightjs": "14.0.1",
    "ngx-logger": "5.0.12",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular/build": "21.1.2",
    "@angular/cli": "21.1.2",
    "@angular/compiler-cli": "21.1.2",
    "@types/jasmine": "6.0.0",
    "@types/node": "22.19.7",
    "core-schematics": "file:schematics",
    "jasmine": "6.0.0",
    "jasmine-core": "6.0.1",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "karma-junit-reporter": "2.0.1",
    "karma-sonarqube-unit-reporter": "0.0.23",
    "ng-mocks": "14.15.0",
    "ng-packagr": "21.1.0",
    "npm-run-all": "4.1.5",
    "typescript": "5.9.3",
    "wait-on": "9.0.3"
  }
}
